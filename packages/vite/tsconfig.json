{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "#shared/*": ["../../shared/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "../../shared/src/**/*"]
}
